# UI テスト用コンテナ
# 通常の app Dockerfile をベースに Playwright + Chromium を追加する。
# Chromium のシステム依存が大きいため、本番 Dockerfile とは分けている。
FROM python:3.11-slim

WORKDIR /app

# アプリ依存（本番と同じ）
COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

# Playwright + pytest-playwright のインストール
RUN pip install pytest-playwright playwright

# Chromium とそのシステム依存をインストール（--with-deps で apt 依存も解決）
RUN playwright install chromium --with-deps

COPY . .
